[gd_scene load_steps=5 format=3 uid="uid://game_over"]

[ext_resource type="Script" path="res://scripts/game_over.gd" id="1_game_over"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_restart"]
bg_color = Color(0.18, 0.68, 0.18, 1)
corner_radius_top_left = 10
corner_radius_top_right = 10
corner_radius_bottom_right = 10
corner_radius_bottom_left = 10

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_menu"]
bg_color = Color(0.2, 0.4, 0.85, 1)
corner_radius_top_left = 10
corner_radius_top_right = 10
corner_radius_bottom_right = 10
corner_radius_bottom_left = 10

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_panel"]
bg_color = Color(0.06, 0.06, 0.12, 0.95)
corner_radius_top_left = 20
corner_radius_top_right = 20
corner_radius_bottom_right = 20
corner_radius_bottom_left = 20

[node name="GameOver" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_game_over")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.06, 0.06, 0.12, 1)

[node name="Panel" type="PanelContainer" parent="."]
layout_mode = 1
offset_left = 340.0
offset_top = 120.0
offset_right = 940.0
offset_bottom = 600.0
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 20

[node name="TitleLabel" type="Label" parent="Panel/VBox"]
custom_minimum_size = Vector2(600, 0)
theme_override_font_sizes/font_size = 72
horizontal_alignment = 1
text = "GAME OVER"
theme_override_colors/font_color = Color(1.0, 0.25, 0.25, 1)

[node name="FinalScore" type="Label" parent="Panel/VBox"]
theme_override_font_sizes/font_size = 46
horizontal_alignment = 1
text = "Score: 0"
theme_override_colors/font_color = Color(1, 1, 1, 1)

[node name="GarbageLabel" type="Label" parent="Panel/VBox"]
theme_override_font_sizes/font_size = 32
horizontal_alignment = 1
text = "Bags Collected: 0"
theme_override_colors/font_color = Color(1.0, 0.85, 0.1, 1)

[node name="BestScore" type="Label" parent="Panel/VBox"]
theme_override_font_sizes/font_size = 28
horizontal_alignment = 1
text = "Best: 0"
theme_override_colors/font_color = Color(0.7, 0.7, 0.8, 1)

[node name="NewHighScore" type="Label" parent="Panel/VBox"]
theme_override_font_sizes/font_size = 32
horizontal_alignment = 1
text = "⭐ NEW HIGH SCORE! ⭐"
theme_override_colors/font_color = Color(1.0, 0.85, 0.0, 1)
visible = false

[node name="Spacer" type="Control" parent="Panel/VBox"]
custom_minimum_size = Vector2(0, 10)

[node name="ButtonRow" type="HBoxContainer" parent="Panel/VBox"]
theme_override_constants/separation = 16
alignment = 1

[node name="RestartButton" type="Button" parent="Panel/VBox/ButtonRow"]
custom_minimum_size = Vector2(240, 65)
theme_override_font_sizes/font_size = 30
